{
  "expo": {
    "name": "Devourin Kiosk",
    "slug": "devourin-kiosk",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icons/app_icon.png",
    "scheme": "devourinkiosk",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pushkara.devourinkiosk"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/icons/app_icon.png",
        "backgroundImage": "./assets/icons/app_icon.png",
        "monochromeImage": "./assets/icons/app_icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.pushkara.devourinkiosk"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icons/app_icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/app_icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Poppins-Black.ttf",
            "./assets/fonts/Poppins-Bold.ttf",
            "./assets/fonts/Poppins-Light.ttf",
            "./assets/fonts/Poppins-Medium.ttf",
            "./assets/fonts/Poppins-Regular.ttf",
            "./assets/fonts/Poppins-SemiBold.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}